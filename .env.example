# Firebase Configuration
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_MEASUREMENT_ID=""

# ── Invitation Email (GitHub Actions → Resend) ──────────────────────────────
# The Resend API key is NOT set here. It lives as the RESEND_API_KEY GitHub
# repository secret so it is never bundled into the browser. See docs/EMAIL.md.
#
# The client only triggers the workflow via repository_dispatch, which needs:
#   - VITE_GH_REPO: "owner/repo" of this repository
#   - VITE_GH_DISPATCH_TOKEN: a fine-grained PAT scoped to THIS repo only, with
#       "Actions: read/write" (and "Contents: read"). Nothing else.
#   - VITE_APP_URL: public base URL used to build the accept-invite link.
VITE_GH_REPO=""
VITE_GH_DISPATCH_TOKEN=""
VITE_APP_URL="http://localhost:5173"
